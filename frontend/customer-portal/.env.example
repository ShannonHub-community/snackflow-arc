# ============================================================
# SnackFlow Customer Portal - Environment Variables (example)
# Copy this file to `.env` and fill in real values.
# NEVER commit the real `.env` file to version control.
# ============================================================

# ---------- API ----------
# Backend API base URL (Vite injects via import.meta.env)
VITE_API_URL=
VITE_API_BASE_URL=

# ---------- AI (optional) ----------
GEMINI_API_KEY=
