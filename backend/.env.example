# ============================================================
# SnackFlow Backend - Environment Variables (example)
# Copy this file to `.env` and fill in real values.
# NEVER commit the real `.env` file to version control.
# ============================================================

# ---------- App ----------
APP_NAME=SnackFlow API
APP_ENV=development            # development | staging | production
DEBUG=true
API_V1_PREFIX=/api

# ---------- Database (Supabase Postgres) ----------
# Use the "Session pooler" (port 6543) connection string from Supabase for
# serverless/many-connections deployments, or the direct 5432 URL locally.
DATABASE_URL=postgresql://postgres:password@db.xxxxxxxx.supabase.co:5432/postgres
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ---------- Redis (Upstash or local) ----------
REDIS_URL=redis://localhost:6379/0
# For Upstash use the rediss:// TLS URL, e.g.
# REDIS_URL=rediss://default:<password>@<region>.upstash.io:6379

# ---------- Security ----------
SECRET_KEY=change_this_to_a_long_random_string
ACCESS_TOKEN_EXPIRE_MINUTES=60
ADMIN_API_KEY=change_this_admin_key   # simple header-based admin auth for staff routes

# ---------- CORS ----------
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ---------- Razorpay ----------
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxx

# ---------- Business Rules ----------
MAX_ITEMS_PER_ORDER=10
ORDER_ID_PREFIX=A
SESSION_TTL_HOURS=6
BASE_PREP_TIME_MINUTES=8
AVG_TIME_PER_QUEUED_ORDER_MINUTES=4

# ---------- Rate Limiting ----------
ORDER_RATE_LIMIT_MAX=3
ORDER_RATE_LIMIT_WINDOW_SECONDS=900

# ---------- Scheduler ----------
DAILY_RESET_HOUR=23
DAILY_RESET_MINUTE=59
TIMEZONE=Asia/Kolkata

# ---------- Logging ----------
LOG_LEVEL=INFO
